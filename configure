#! /bin/sh

"${R_HOME}/bin/Rscript" -e "rstantools::rstan_config()"

# Add configuration needed for big object files
echo "PKG_CXXFLAGS += -Wa,-mbig-obj" >> ./src/Makevars

# Append optimization flags without losing existing include paths
echo "CXX14FLAGS += -O3 -march=native -mtune=native" >> src/Makevars
echo "PKG_CPPFLAGS += -DSTAN_THREADS" >> src/Makevars
